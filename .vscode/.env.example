# Copy this file to .vscode/.env and set values for your machine.
# .vscode/.env is ignored by git.

# Preferred: full path to the Node MCP entrypoint
# GODOT_MCP_SERVER_ENTRY=C:/Users/you/code/godot-mcp/server/dist/index.js

# Alternative: root of the godot-mcp repository (not needed if GODOT_MCP_SERVER_ENTRY is set)
# GODOT_MCP_ROOT=C:/Users/you/code/godot-mcp
